---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
                        title="Experience | Abdullahi Abubakar Ahmed"
			description="Professional and research experience in mechanical engineering, hydrogen modelling, sustainable energy, additive manufacturing, maintenance, and QA/QC inspection."
		/>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>

		<style is:inline>
			html,
			body {
				background-color: #0d0d0e !important;
				background-image: none !important;
				color: #ffffff !important;
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
				margin: 0;
				padding: 0;
			}

			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 7rem 2rem;
				background-color: #0d0d0e !important;
			}

			.page-header {
				margin-bottom: 5rem;
				border-left: 5px solid #ff5a2b;
				padding-left: 2rem;
			}

			.page-label {
				display: block;
				color: #ff5a2b !important;
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				margin-bottom: 1rem;
			}

			.page-title {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 3.8rem;
				font-weight: 800;
				color: #ffffff !important;
				margin: 0 0 0.8rem;
				letter-spacing: -0.04em;
				line-height: 1.05;
			}

			.page-subtitle {
				color: #a1a1aa !important;
				font-size: 1.2rem;
				font-weight: 500;
				margin: 0;
				max-width: 780px;
				line-height: 1.7;
				letter-spacing: -0.01em;
			}

			.section-header {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin: 5.5rem 0 2.5rem;
			}

			.section-header:first-of-type {
				margin-top: 0;
			}

			.section-title {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.9rem;
				font-weight: 700;
				color: #ffffff !important;
				margin: 0;
				letter-spacing: -0.03em;
			}

			.section-line {
				flex: 1;
				height: 1px;
				background: #27272a;
			}

			.timeline-container {
				position: relative;
				padding-left: 2.5rem;
			}

			.timeline-container::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0.5rem;
				width: 1px;
				height: calc(100% - 1rem);
				background: #27272a !important;
			}

			.experience-entry {
				position: relative;
				margin-bottom: 3rem;
			}

			.experience-entry:last-child {
				margin-bottom: 0;
			}

			.timeline-marker {
				position: absolute;
				left: -2.5rem;
				top: 1.4rem;
				width: 13px;
				height: 13px;
				background-color: #0d0d0e;
				border: 3px solid #ff5a2b;
				border-radius: 50%;
				z-index: 5;
				transform: translateX(-6px);
			}

			.experience-content-card {
				background: #1a1a1c !important;
				border: 1px solid #27272a !important;
				border-radius: 22px;
				padding: 2.8rem;
				transition:
					border-color 0.25s ease,
					transform 0.25s ease;
			}

			.experience-content-card:hover {
				border-color: #ff5a2b !important;
				transform: translateY(-3px);
			}

			.entry-topline {
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 0.8rem;
				margin-bottom: 1rem;
			}

			.date-tag {
				color: #ff5a2b !important;
				font-size: 0.88rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.09em;
			}

			.entry-type {
				display: inline-flex;
				align-items: center;
				padding: 0.4rem 0.8rem;
				background: rgba(255, 90, 43, 0.08);
				border: 1px solid rgba(255, 90, 43, 0.25);
				border-radius: 999px;
				color: #ff8a68 !important;
				font-size: 0.78rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.07em;
			}

			.role-title {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.8rem;
				font-weight: 700;
				color: #ffffff !important;
				margin: 0 0 0.6rem;
				letter-spacing: -0.025em;
				line-height: 1.3;
			}

			.company-meta {
				color: #a1a1aa !important;
				font-size: 1.02rem;
				font-weight: 500;
				line-height: 1.6;
				margin: 0 0 1.8rem;
				border-bottom: 1px solid #27272a;
				padding-bottom: 1.3rem;
			}

			.company-name {
				color: #ffffff !important;
				font-weight: 600;
			}

			.location-tag {
				color: #d1d5db !important;
				font-weight: 500;
			}

			.bullet-container ul {
				padding-left: 1.25rem;
				margin: 0;
				color: #d1d5db !important;
				font-size: 1.03rem;
				line-height: 1.8;
				letter-spacing: -0.01em;
			}

			.bullet-container li {
				margin-bottom: 0.8rem;
				padding-left: 0.25rem;
			}

			.bullet-container li:last-child {
				margin-bottom: 0;
			}

			.bullet-container li::marker {
				color: #ff5a2b;
			}

			.skill-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
				margin-top: 1.8rem;
			}

			.skill-tag {
				display: inline-flex;
				align-items: center;
				padding: 0.48rem 0.85rem;
				background: #202023;
				border: 1px solid #303034;
				border-radius: 999px;
				color: #c4c4cc !important;
				font-size: 0.8rem;
				font-weight: 600;
			}

			.summary-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.2rem;
				margin-top: 5rem;
			}

			.summary-card {
				background: #151517;
				border: 1px solid #27272a;
				border-radius: 18px;
				padding: 1.8rem;
			}

			.summary-card strong {
				display: block;
				color: #ffffff !important;
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.1rem;
				margin-bottom: 0.45rem;
			}

			.summary-card span {
				color: #8f8f98 !important;
				font-size: 0.9rem;
				line-height: 1.55;
			}

			@media (max-width: 900px) {
				main {
					padding: 5rem 1.5rem;
				}

				.page-title {
					font-size: 3rem;
				}

				.summary-grid {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 768px) {
				main {
					padding: 4.5rem 1.2rem;
				}

				.page-header {
					padding-left: 1.25rem;
					margin-bottom: 3.5rem;
				}

				.page-title {
					font-size: 2.7rem;
				}

				.page-subtitle {
					font-size: 1.05rem;
				}

				.timeline-container {
					padding-left: 1.75rem;
				}

				.timeline-marker {
					left: -1.75rem;
				}

				.experience-content-card {
					padding: 2rem;
				}

				.role-title {
					font-size: 1.45rem;
				}

				.section-title {
					font-size: 1.6rem;
				}
			}

			@media (max-width: 480px) {
				.experience-content-card {
					padding: 1.5rem;
					border-radius: 16px;
				}

				.entry-topline {
					align-items: flex-start;
					flex-direction: column;
				}

				.bullet-container ul {
					font-size: 0.98rem;
					line-height: 1.7;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<div class="page-header">
				<span class="page-label">Professional Journey</span>

				<h1 class="page-title">Experience</h1>

