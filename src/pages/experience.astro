						</div>
					</article>

					<article class="experience-entry">
						<div class="timeline-marker" aria-hidden="true"></div>

						<div class="experience-content-card">
							<div class="entry-topline">
								<span class="date-tag">
									February 2022 â€“ August 2022
								</span>

