---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Experience | ${SITE_TITLE}`} description="Professional engineering track." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
		
		<style is:inline>
			/* The 'is:inline' directive forces Astro to prioritize these styles over any broken global CSS files */
			html, body {
				background-color: #0d0d0e !important; /* Force true pitch black background from image */
				background-image: none !important;    /* Wipe away any ugly gray background gradients */
				color: #ffffff !important;
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
				margin: 0;
				padding: 0;
			}
			
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 6rem 2rem;
				background-color: #0d0d0e !important;
			}

			/* Page Header Structure */
			.page-header {
				margin-bottom: 5rem;
				border-left: 5px solid #ff5a2b; /* Precise orange accent line */
				padding-left: 2rem;
			}

			.page-title {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 3.5rem;
				font-weight: 800;
				color: #ffffff !important;
				margin: 0 0 0.5rem 0;
				letter-spacing: -0.03em;
				line-height: 1.1;
			}

			.page-subtitle {
				color: #a1a1aa !important; /* Perfectly readable grey text */
				font-size: 1.3rem;
				font-weight: 500;
				margin: 0;
				max-width: 700px;
				line-height: 1.6;
			}

			/* Timeline Architecture */
			.timeline-container {
				position: relative;
				padding-left: 2.5rem;
				margin-top: 2rem;
			}

			.timeline-container::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0;
				width: 1px;
				height: 100%;
				background: #27272a !important; /* Soft dark line divider */
			}

			.experience-entry {
				position: relative;
				margin-bottom: 4rem;
			}

			.timeline-marker {
				position: absolute;
				left: -2.5rem;
				top: 8px;
				width: 12px;
				height: 12px;
				background-color: #0d0d0e;
				border: 3px solid #ff5a2b; /* Vibrant orange inner dot */
				border-radius: 50%;
				z-index: 5;
			}

			/* Content Cards matching Eliott's theme layout */
			.experience-content-card {
				background: #1a1a1c !important; /* Lighter charcoal card container */
				border: 1px solid #27272a !important;
				border-radius: 20px;
				padding: 2.5rem;
			}

			.date-tag {
				color: #ff5a2b !important;
				font-size: 0.95rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 0.8rem;
				display: block;
			}

			.role-title {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 2rem;
				font-weight: 700;
				color: #ffffff !important;
				margin: 0 0 0.5rem 0;
				letter-spacing: -0.02em;
			}

			.company-meta {
				color: #a1a1aa !important;
				font-size: 1.1rem;
				font-weight: 500;
				margin-bottom: 1.5rem;
				border-bottom: 1px solid #27272a;
				padding-bottom: 1rem;
			}

			.location-tag {
				font-weight: 600;
				color: #ffffff !important;
			}

			.bullet-container ul {
				padding-left: 1.2rem;
				margin: 0;
				color: #d1d5db !important; /* High contrast readable details */
				font-size: 1.05rem;
				line-height: 1.8;
			}

			.bullet-container li {
				margin-bottom: 0.8rem;
			}

			@media (max-width: 768px) {
				.page-title { font-size: 2.8rem; }
				.role-title { font-size: 1.6rem; }
				.experience-content-card { padding: 1.8rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			
			<div class="page-header">
				<h1 class="page-title">Operational History</h1>
				<p class="page-subtitle">Timeline track focused on technical auditing, localized infrastructure, and localized mechanical systems.</p>
			</div>

			<div class="timeline-container">
				
				<!-- Role 1 -->
				<article class="experience-entry">
					<div class="timeline-marker"></div>
					<div class="experience-content-card">
						<span class="date-tag">Jun 2021 – Present</span>
						<h2 class="role-title">Infrastructure Technical Auditor</h2>
						<p class="company-meta">
							Freelance Operations • <span class="location-tag">Lombardy, Italy / Remote</span>
						</p>
						<div class="bullet-container">
							<ul>
								<li>Executing macro-level compliance evaluations for decentralized renewable infrastructure configurations in line with specialized regulatory loops.</li>
								<li>Implementing thermodynamic validations and techno-economic transient analysis for optimized micro-grid architectures.</li>
								<li>Synthesizing operational risk matrices and efficiency benchmarks for specialized manufacturing asset pools.</li>
							</ul>
						</div>
					</div>
				</article>

				<!-- Role 2 -->
				<article class="experience-entry">
					<div class="timeline-marker"></div>
					<div class="experience-content-card">
						<span class="date-tag">Aug 2019 – May 2021</span>
						<h2 class="role-title">Localized Infrastructure Design Auditor</h2>
						<p class="company-meta">
							Contractual Audit Tracks • <span class="location-tag">Bari, Apulia, Italy / Remote</span>
						</p>
						<div class="bullet-container">
							<ul>
								<li>Audited mechanical system specifications and architectural execution blueprints for residential energy grid transitions in compliance with local regulations.</li>
								<li>Validated AutoCAD schematic accuracy and structural boundary limits for primary load-bearing localized elements.</li>
								<li>Provided technical feasibility modeling and layout simulations for optimized HVAC loop configurations in specialized renovations.</li>
							</ul>
						</div>
					</div>
				</article>

			</div>

		</main>
		<Footer />
	</body>
</html>