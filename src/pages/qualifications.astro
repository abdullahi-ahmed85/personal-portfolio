
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<meta
			name="description"
			content="Education, professional development, scholarships, and language skills of Abdullahi Abubakar Ahmed."
		/>

		<title>Qualifications | Abdullahi Abubakar Ahmed</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>

		<style>
			:root {
				--background: #0d0d0e;
				--surface: #1a1a1c;
				--surface-light: #202023;
				--border: #2c2c30;
				--text: #ffffff;
				--text-secondary: #d1d5db;
				--text-muted: #a1a1aa;
				--accent: #ff5a2b;
				--accent-hover: #ff7147;
			}

			* {
				box-sizing: border-box;
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				margin: 0;
				background: var(--background);
				color: var(--text);
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.site-header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: rgba(13, 13, 14, 0.92);
				border-bottom: 1px solid var(--border);
				backdrop-filter: blur(14px);
			}

			.navigation {
				max-width: 1200px;
				min-height: 76px;
				margin: 0 auto;
				padding: 0 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 2rem;
			}

			.brand {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.15rem;
				font-weight: 800;
				letter-spacing: -0.03em;
				white-space: nowrap;
			}

			.brand span {
				color: var(--accent);
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 1.8rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.nav-links a {
				color: var(--text-muted);
				font-size: 0.95rem;
				font-weight: 600;
				transition: color 0.2s ease;
			}

			.nav-links a:hover,
			.nav-links a.active {
				color: var(--accent);
			}

			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 7rem 2rem;
			}

			.page-header {
				margin-bottom: 5rem;
				padding-left: 2rem;
				border-left: 5px solid var(--accent);
			}

			.page-label {
				display: inline-block;
				margin-bottom: 1rem;
				color: var(--accent);
				font-size: 0.85rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			.page-title {
				margin: 0 0 0.8rem;
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: clamp(2.8rem, 7vw, 4.5rem);
				font-weight: 800;
				line-height: 1.05;
				letter-spacing: -0.05em;
			}

			.page-subtitle {
				max-width: 780px;
				margin: 0;
				color: var(--text-muted);
				font-size: 1.15rem;
				font-weight: 500;
				line-height: 1.7;
			}

			.section-heading {
				margin: 5.5rem 0 2rem;
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.9rem;
				font-weight: 700;
				letter-spacing: -0.03em;
			}

			.qual-card {
				margin-bottom: 1.8rem;
				padding: 2.8rem;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 22px;
				transition:
					border-color 0.25s ease,
					transform 0.25s ease;
			}

			.qual-card:hover {
				border-color: var(--accent);
				transform: translateY(-3px);
			}

			.qual-card h3 {
				margin: 0 0 0.7rem;
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.65rem;
				font-weight: 700;
				line-height: 1.3;
				letter-spacing: -0.025em;
			}

			.meta-line {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.55rem;
				margin-bottom: 1.8rem;
				color: var(--accent);
				font-size: 0.95rem;
				font-weight: 600;
			}

			.meta-dot {
				font-size: 0.75rem;
			}

			.qual-card-details {
				color: var(--text-secondary);
				font-size: 1.03rem;
				line-height: 1.8;
			}

			.qual-card-details p {
				margin: 0 0 1rem;
			}

			.qual-card-details p:last-child {
				margin-bottom: 0;
			}

			.qual-card-details strong {
				color: var(--text);
				font-weight: 600;
			}

			.credentials-container {
				padding: 2.8rem;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 22px;
			}

			.credentials-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.credential-item {
				padding-bottom: 1.5rem;
				color: var(--text-secondary);
				font-size: 1.03rem;
				line-height: 1.65;
				border-bottom: 1px solid var(--border);
			}

			.credential-item:last-child {
				padding-bottom: 0;
				border-bottom: none;
			}

			.credential-item strong {
				display: block;
				margin-bottom: 0.35rem;
				color: var(--text);
				font-size: 1.1rem;
				font-weight: 600;
			}

			.credential-meta {
				color: var(--accent);
				font-size: 0.92rem;
				font-weight: 600;
			}

			.language-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
				gap: 1.2rem;
			}

			.language-block {
				padding: 1.6rem;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 16px;
				transition:
					border-color 0.2s ease,
					transform 0.2s ease;
			}

			.language-block:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
			}

			.language-block strong {
				display: block;
				margin-bottom: 0.4rem;
				font-size: 1.15rem;
				letter-spacing: -0.02em;
			}

			.language-block span {
				color: var(--text-muted);
				font-size: 0.95rem;
				font-weight: 500;
			}

			.site-footer {
				border-top: 1px solid var(--border);
			}

			.footer-content {
				max-width: 1200px;
				margin: 0 auto;
				padding: 2.5rem 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1.5rem;
				color: var(--text-muted);
				font-size: 0.9rem;
			}

			.footer-content a {
				color: var(--text-secondary);
				transition: color 0.2s ease;
			}

			.footer-content a:hover {
				color: var(--accent);
			}

			@media (max-width: 850px) {
				.navigation {
					padding: 1rem 1.25rem;
					align-items: flex-start;
					flex-direction: column;
					gap: 1rem;
				}

				.nav-links {
					width: 100%;
					gap: 1.2rem;
					overflow-x: auto;
					padding-bottom: 0.4rem;
				}

				main {
					padding: 5rem 1.25rem;
				}

				.page-header {
					padding-left: 1.25rem;
					margin-bottom: 3.5rem;
				}

				.qual-card,
				.credentials-container {
					padding: 2rem;
				}

				.qual-card h3 {
					font-size: 1.4rem;
				}

				.footer-content {
					padding: 2rem 1.25rem;
					align-items: flex-start;
					flex-direction: column;
				}
			}

			@media (max-width: 520px) {
				.qual-card,
				.credentials-container {
					padding: 1.5rem;
					border-radius: 16px;
				}

				.page-subtitle {
					font-size: 1rem;
				}

				.section-heading {
					font-size: 1.6rem;
				}
			}
		</style>
	</head>

