---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Qualifications | Abdullahi Abubakar Ahmed"
			description="Education, professional development, scholarships, and language skills of Abdullahi Abubakar Ahmed."
		/>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>

		<style is:inline>
			:root {
				--page-background: #f7f7f5;
				--surface: #ffffff;
				--surface-soft: #f0f2f5;
				--text: #0b0b0b;
				--muted: #4b5563;
				--accent: #2f3b5c;
				--accent-hover: #1f293f;
				--border: #e2e5e9;
				--shadow: rgba(47, 59, 92, 0.09);
			}

			* {
				box-sizing: border-box;
			}

			html {
				background: var(--page-background);
				scroll-behavior: smooth;
			}

			body {
				margin: 0;
				background: var(--page-background);
				color: var(--text);
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 5.5rem 2rem 6rem;
			}

			h1,
			h2,
			h3 {
				font-family: 'Plus Jakarta Sans', sans-serif;
			}

			.page-header {
				max-width: 850px;
				margin-bottom: 4rem;
			}

			.page-label {
				display: block;
				margin-bottom: 1rem;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 800;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			.page-title {
				margin: 0 0 1rem;
				color: var(--text);
				font-size: clamp(2.8rem, 6vw, 4.8rem);
				font-weight: 800;
				line-height: 1.04;
				letter-spacing: -0.05em;
			}

			.page-subtitle {
				max-width: 780px;
				margin: 0;
				color: var(--muted);
				font-size: 1.08rem;
				line-height: 1.75;
			}

			.section-heading {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin: 5rem 0 2rem;
				color: var(--text);
				font-size: 1.8rem;
				font-weight: 700;
				letter-spacing: -0.03em;
			}

			.section-heading::after {
				content: '';
				flex: 1;
				height: 1px;
				background: var(--border);
			}

			.section-heading.first-section {
				margin-top: 0;
			}

			.qual-card,
			.credentials-container,
			.language-block {
				border: 1px solid var(--border);
				background: var(--surface);
				box-shadow: 0 16px 40px var(--shadow);
			}

			.qual-card {
				margin-bottom: 1.25rem;
				padding: 2.3rem;
				border-radius: 20px;
				transition:
					transform 0.2s ease,
					border-color 0.2s ease,
					box-shadow 0.2s ease;
			}

			.qual-card:hover {
				transform: translateY(-3px);
				border-color: #c9d0d9;
				box-shadow: 0 22px 50px rgba(47, 59, 92, 0.13);
			}

			.qual-card h3 {
				margin: 0 0 0.7rem;
				color: var(--text);
				font-size: 1.6rem;
				font-weight: 700;
				line-height: 1.3;
				letter-spacing: -0.025em;
			}

			.meta-line {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.55rem;
				margin-bottom: 1.5rem;
				padding-bottom: 1.2rem;
				border-bottom: 1px solid var(--border);
				color: var(--accent);
				font-size: 0.92rem;
				font-weight: 700;
			}

			.meta-dot {
				font-size: 0.7rem;
			}

			.qual-card-details {
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.78;
			}

			.qual-card-details p {
				margin: 0 0 1rem;
			}

			.qual-card-details p:last-child {
				margin-bottom: 0;
			}

			.qual-card-details strong {
				color: var(--text);
				font-weight: 700;
			}

			.credentials-container {
				padding: 2rem;
				border-radius: 20px;
			}

			.credentials-list {
				display: grid;
				gap: 0;
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.credential-item {
				padding: 1.25rem 0;
				border-bottom: 1px solid var(--border);
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.65;
			}

			.credential-item:first-child {
				padding-top: 0;
			}

			.credential-item:last-child {
				padding-bottom: 0;
				border-bottom: none;
			}

			.credential-item strong {
				display: block;
				margin-bottom: 0.35rem;
				color: var(--text);
				font-size: 1.08rem;
				font-weight: 700;
			}

			.credential-meta {
				color: var(--accent);
				font-size: 0.9rem;
				font-weight: 700;
			}

			.language-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 1rem;
			}

			.language-block {
				padding: 1.5rem;
				border-radius: 16px;
				transition:
					transform 0.2s ease,
					border-color 0.2s ease,
					box-shadow 0.2s ease;
			}

			.language-block:hover {
				transform: translateY(-2px);
				border-color: #c9d0d9;
				box-shadow: 0 20px 44px rgba(47, 59, 92, 0.12);
			}

			.language-block strong {
				display: block;
				margin-bottom: 0.4rem;
				color: var(--text);
				font-size: 1.1rem;
				letter-spacing: -0.02em;
			}

			.language-block span {
				color: var(--muted);
				font-size: 0.92rem;
				line-height: 1.5;
			}

			@media (max-width: 900px) {
				main {
					padding-top: 4.5rem;
				}

				.language-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (max-width: 650px) {
				main {
					padding: 3.5rem 1.2rem 4rem;
				}

				.page-header {
					margin-bottom: 3rem;
				}

				.page-subtitle {
					font-size: 1rem;
				}

				.section-heading {
					margin-top: 4rem;
					font-size: 1.55rem;
				}

				.qual-card,
				.credentials-container {
					padding: 1.5rem;
					border-radius: 16px;
				}

				.qual-card h3 {
					font-size: 1.35rem;
				}

				.meta-line {
					align-items: flex-start;
					flex-direction: column;
					gap: 0.25rem;
				}

				.meta-dot {
					display: none;
				}

				.language-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<header class="page-header">
				<span class="page-label">Academic Profile</span>

				<h1 class="page-title">Education & Qualifications</h1>

				<p class="page-subtitle">
					Academic degrees, sustainable-energy specialisation,
					professional development, scholarships, and international
					communication skills.
				</p>
			</header>

			<section aria-labelledby="degrees-heading">
				<h2 id="degrees-heading" class="section-heading first-section">
					University Degrees & Specialisations
				</h2>

				<article class="qual-card">
					<h3>
						Master Universitario di I Livello in Sustainable Energy
					</h3>

					<div class="meta-line">
						<span class="meta-dot">●</span>
						<span>European Specialization School – SkillBill</span>
						<span>•</span>
						<span>October 2024 – February 2026</span>
					</div>

					<div class="qual-card-details">
						<p>
							<strong>Qualification:</strong>
							First-Level University Master, 60 ECTS, Grade A.
						</p>

						<p>
							<strong>Primary focus:</strong>
							Hydrogen technologies, renewable fuels, ammonia and
							e-fuels, energy storage, sustainable mobility,
							circular economy, energy management, and sustainable
							energy-system integration.
						</p>

						<p>
							<strong>Final project:</strong>
							Hydrogen Refuelling Stations, Storage Tank Behaviour,
							and Adiabatic Blowdown Simulation.
						</p>

						<p>
							Developed a MATLAB numerical model of a 700-bar
							Type IV hydrogen storage tank using mass and energy
							conservation equations, fourth-order Runge–Kutta
							integration, and MATLAB ode45.
						</p>
					</div>
				</article>

				<article class="qual-card">
					<h3>Master of Science in Mechanical Engineering</h3>

					<div class="meta-line">
						<span class="meta-dot">●</span>
						<span>University of Tuscia, Italy</span>
						<span>•</span>
						<span>September 2022 – May 2025</span>
					</div>

					<div class="qual-card-details">
						<p>
							<strong>Qualification:</strong>
							M.Sc. in Mechanical Engineering, 120 ECTS,
							Final Grade 98/110.
						</p>

						<p>
							<strong>Language of instruction:</strong>
							English.
						</p>

						<p>
							<strong>Relevant coursework:</strong>
							Numerical thermo-fluid dynamics, sensors and data
							acquisition systems, advanced manufacturing,
							machine design, virtual prototyping,
							non-destructive testing, environmental monitoring,
							and project and industrial management.
						</p>

						<p>
							<strong>Thesis:</strong>
							Use of Non-contact Techniques to Estimate the
							Distortion of Parts Built by Additive Manufacturing,
							Particularly Polymeric FDM.
						</p>
					</div>
				</article>

				<article class="qual-card">
					<h3>Bachelor’s Degree in Mechanical Engineering</h3>

					<div class="meta-line">
						<span class="meta-dot">●</span>
						<span>Somali National University, Somalia</span>
						<span>•</span>
						<span>February 2017 – March 2022</span>
					</div>

					<div class="qual-card-details">
						<p>
							<strong>Final Grade:</strong>
							110/110.
						</p>

						<p>
							<strong>Thesis:</strong>
							Analysis of the Factors Influencing Fuel Consumption
							in Passenger Vehicles.
						</p>
					</div>
				</article>

				<article class="qual-card">
					<h3>Professional Diploma in Project Management</h3>

					<div class="meta-line">
						<span class="meta-dot">●</span>
						<span>Mogadishu University, Somalia</span>
						<span>•</span>
						<span>September 2019 – October 2020</span>
					</div>

					<div class="qual-card-details">
						<p>
							<strong>Programme focus:</strong>
							Project planning, scheduling, budgeting, risk
							management, monitoring, reporting, and evaluation.
						</p>
					</div>
				</article>
			</section>

			<section aria-labelledby="certifications-heading">
				<h2 id="certifications-heading" class="section-heading">
					Certifications & Professional Development
				</h2>

				<div class="credentials-container">
					<ul class="credentials-list">
						<li class="credential-item">
							<strong>Additive Manufacturing</strong>

							<span class="credential-meta">
								University of Michigan, Coursera —
								June to August 2023
							</span>
						</li>

						<li class="credential-item">
							<strong>Digital Manufacturing and Design</strong>

							<span class="credential-meta">
								University at Buffalo, Coursera —
								March to April 2023
							</span>
						</li>

						<li class="credential-item">
							<strong>
								Solar Energy and Electrical System Design
							</strong>

							<span class="credential-meta">
								University at Buffalo, Coursera —
								December 2021 to January 2022
							</span>
						</li>
					</ul>
				</div>
			</section>

			<section aria-labelledby="awards-heading">
				<h2 id="awards-heading" class="section-heading">
					Scholarships & Academic Awards
				</h2>

				<div class="credentials-container">
					<ul class="credentials-list">
						<li class="credential-item">
							<strong>MED-OR Foundation Scholarship</strong>

							<span class="credential-meta">
								M.Sc. Mechanical Engineering,
								University of Tuscia — 2022 to 2024
							</span>
						</li>

						<li class="credential-item">
							<strong>Erasmus+ Scholarship</strong>

							<span class="credential-meta">
								SkillBill European Sustainable Energy Programme —
								2024 to 2025
							</span>
						</li>
					</ul>
				</div>
			</section>

			<section aria-labelledby="languages-heading">
				<h2 id="languages-heading" class="section-heading">
					Language Skills
				</h2>

				<div class="language-grid">
					<div class="language-block">
						<strong>Somali</strong>
						<span>Mother tongue</span>
					</div>

					<div class="language-block">
						<strong>English</strong>
						<span>Advanced / proficient</span>
					</div>

					<div class="language-block">
						<strong>Arabic</strong>
						<span>Advanced / proficient</span>
					</div>

					<div class="language-block">
						<strong>Italian</strong>
						<span>Basic to intermediate</span>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
