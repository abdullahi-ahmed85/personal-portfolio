---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
		
		<style is:inline>
			html, body {
				background-color: #0d0d0e !important;
				background-image: none !important;
				color: #ffffff !important;
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
				margin: 0;
				padding: 0;
			}
			
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 7rem 2rem;
				background-color: #0d0d0e !important;
			}

			/* Asymmetric Grid Layout */
			.hero-split {
				display: grid;
				grid-template-columns: 1.25fr 0.75fr;
				gap: 5rem;
				align-items: center;
				margin-bottom: 6rem;
			}

			/* Text Format: Clean Tracking for Status Badge */
			.badge-status {
				color: #ff5a2b !important;
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.14em; /* Wide tracking for modern tech badge feel */
				margin-bottom: 1.5rem;
			}

			/* Text Format: Tight, Compressed, Bold Headline */
			.main-headline {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 4.6rem;
				font-weight: 800;
				line-height: 1.05; /* Keeps large headings tightly stacked */
				letter-spacing: -0.04em; /* High-end compressed tracking */
				margin: 0 0 1.8rem 0;
				color: #ffffff !important;
			}

			.main-headline span {
				color: #ff5a2b !important;
				letter-spacing: -0.02em;
			}

			/* Text Format: Balanced Line Height for Sub-Bios */
			.sub-bio {
				color: #a1a1aa !important;
				font-size: 1.2rem;
				line-height: 1.7; /* Extra room for optimal paragraph reading */
				letter-spacing: -0.01em; /* Subtle compression */
				margin-bottom: 3rem;
				max-width: 560px;
			}

			.sub-bio strong {
				color: #ffffff !important;
				font-weight: 600;
			}

			/* Pill Action Controls */
			.btn-row {
				display: flex;
				gap: 1.2rem;
			}

			.pill-btn {
				display: inline-flex;
				align-items: center;
				padding: 0.9rem 2rem;
				border-radius: 9999px;
				font-size: 0.95rem;
				font-weight: 600;
				letter-spacing: -0.01em;
				text-decoration: none;
				transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.btn-white {
				background-color: #ffffff;
				color: #0d0d0e;
			}

			.btn-white:hover {
				background-color: #e2e8f0;
				transform: translateY(-2px);
			}

			.btn-outline {
				background-color: transparent;
				color: #ffffff;
				border: 1px solid #27272a;
			}

			.btn-outline:hover {
				background-color: #141416;
				border-color: #444446;
				transform: translateY(-2px);
			}

			/* Portrait Side Panel */
			.media-container {
				position: relative;
			}

			.media-container::after {
				content: '';
				position: absolute;
				top: -15%;
				right: -15%;
				width: 130%;
				height: 130%;
				background: radial-gradient(circle, rgba(255, 90, 43, 0.09) 0%, transparent 65%);
				z-index: 1;
				pointer-events: none;
			}

			.photo-card {
				position: relative;
				z-index: 2;
				width: 100%;
				aspect-ratio: 1 / 1;
				background-color: #1a1a1c;
				background-image: url('/my-portrait.jpg');
				background-size: cover;
				background-position: center 20%;
				background-repeat: no-repeat;
				border-radius: 32px;
				box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.8);
			}

			.floating-tag {
				position: absolute;
				bottom: -10px;
				left: -10px;
				background-color: #ff5a2b;
				color: #ffffff;
				padding: 0.6rem 1.4rem;
				border-radius: 14px;
				font-size: 0.85rem;
				font-weight: 700;
				letter-spacing: 0.02em;
				text-decoration: none;
				z-index: 3;
				box-shadow: 0 6px 20px rgba(255, 90, 43, 0.35);
				transition: transform 0.2s ease;
			}

			.floating-tag:hover {
				transform: scale(1.04);
			}

			/* Horizontal Summary Line Splitter */
			.counter-row {
				display: flex;
				gap: 5rem;
				border-top: 1px solid #1a1a1c;
				padding-top: 3.5rem;
			}

			/* Text Format: Big Counter Numbers */
			.counter-block h4 {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 2.6rem;
				font-weight: 800;
				margin: 0 0 0.2rem 0;
				letter-spacing: -0.03em; /* Tight number formatting */
				color: #ffffff !important;
			}

			/* Text Format: Tiny, clean counter labels */
			.counter-block p {
				color: #71717a;
				font-size: 0.9rem;
				margin: 0;
				font-weight: 500;
				letter-spacing: -0.01em;
			}

			@media (max-width: 968px) {
				.hero-split { grid-template-columns: 1fr; gap: 4rem; }
				.counter-row { gap: 2.5rem; flex-wrap: wrap; }
				.main-headline { font-size: 3.2rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			
			<div class="hero-split">
				<div class="hero-intro">
					<div class="badge-status">Available for Contracts</div>
					<h1 class="main-headline">Hi, I'm <span>Abdirahman</span></h1>
					<p class="sub-bio">
						Mechanical Engineer & <strong>Energy Systems Analyst</strong>. I model dynamic digital twin frameworks and build sustainable energy infrastructure configurations that are clean, data-validated, and highly resilient.
					</p>
					
					<div class="btn-row">
						<a href="/blog" class="pill-btn btn-white">View my work ↓</a>
						<a 
							href="https://www.linkedin.com/in/dhore" 
							target="_blank" 
							rel="noopener noreferrer" 
							class="pill-btn btn-outline"
						>
							Get in touch ↗
						</a>
					</div>
				</div>

				<div class="media-container">
					<div class="photo-card"></div>
					<a href="/blog" class="floating-tag">Open to projects</a>
				</div>
			</div>

			<div class="counter-row">
				<div class="counter-block">
					<h4>3+</h4>
					<p>Advanced research frameworks</p>
				</div>
				<div class="counter-block">
					<h4>M.Sc.</h4>
					<p>Politecnico di Milano</p>
				</div>
				<div class="counter-block">
					<h4>5y</h4>
					<p>Technical engineering track</p>
				</div>
			</div>

		</main>
		<Footer />
	</body>
</html>