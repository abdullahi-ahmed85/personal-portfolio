---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;700;800&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>

		<style is:inline>
			html,
			body {
				background-color: #08130d !important;
				background-image: none !important;
				color: #ffffff !important;
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
				margin: 0;
				padding: 0;
			}

			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 7rem 2rem;
				background-color: #08130d !important;
			}

			.hero-split {
				display: grid;
				grid-template-columns: 1.25fr 0.75fr;
				gap: 5rem;
				align-items: center;
				margin-bottom: 6rem;
			}

			.badge-status {
				color: #22c55e !important;
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				margin-bottom: 1.5rem;
			}

			.main-headline {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 4.6rem;
				font-weight: 800;
				line-height: 1.05;
				letter-spacing: -0.04em;
				margin: 0 0 1.8rem 0;
				color: #ffffff !important;
			}

			.main-headline span {
				color: #22c55e !important;
				letter-spacing: -0.02em;
			}

			.sub-bio {
				color: #a8b8ad !important;
				font-size: 1.2rem;
				line-height: 1.7;
				letter-spacing: -0.01em;
				margin-bottom: 3rem;
				max-width: 620px;
			}

			.sub-bio strong {
				color: #ffffff !important;
				font-weight: 600;
			}

			.btn-row {
				display: flex;
				flex-wrap: wrap;
				gap: 1.2rem;
			}

			.pill-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.9rem 2rem;
				border-radius: 9999px;
				font-size: 0.95rem;
				font-weight: 600;
				letter-spacing: -0.01em;
				text-decoration: none;
				transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.btn-white {
				background-color: #ffffff;
				color: #08130d;
			}

			.btn-white:hover {
				background-color: #e2e8f0;
				transform: translateY(-2px);
			}

			.btn-outline {
				background-color: transparent;
				color: #ffffff;
				border: 1px solid #284533;
			}

			.btn-outline:hover {
				background-color: #141416;
				border-color: #444446;
				transform: translateY(-2px);
			}

			.media-container {
				position: relative;
			}

			.media-container::after {
				content: '';
				position: absolute;
				top: -15%;
				right: -15%;
				width: 130%;
				height: 130%;
				background: radial-gradient(
					circle,
					rgba(34, 197, 94, 0.09) 0%,
					transparent 65%
				);
				z-index: 1;
				pointer-events: none;
			}

			.photo-card {
				position: relative;
				z-index: 2;
				width: 100%;
				aspect-ratio: 1 / 1;
				background-color: #111c16;
				background-image: url('/my-portrait.jpg');
				background-size: cover;
				background-position: center 20%;
				background-repeat: no-repeat;
				border: 1px solid #284533;
				border-radius: 32px;
				box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.8);
			}

			.floating-tag {
				position: absolute;
				bottom: -10px;
				left: -10px;
				background-color: #22c55e;
				color: #ffffff;
				padding: 0.6rem 1.4rem;
				border-radius: 14px;
				font-size: 0.85rem;
				font-weight: 700;
				letter-spacing: 0.02em;
				text-decoration: none;
				z-index: 3;
				box-shadow: 0 6px 20px rgba(34, 197, 94, 0.35);
				transition: transform 0.2s ease;
			}

			.floating-tag:hover {
				transform: scale(1.04);
			}

			.counter-row {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 3rem;
				border-top: 1px solid #111c16;
				padding-top: 3.5rem;
			}

			.counter-block {
				padding-right: 1rem;
			}

			.counter-block h4 {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 2.6rem;
				font-weight: 800;
				margin: 0 0 0.35rem 0;
				letter-spacing: -0.03em;
				color: #ffffff !important;
			}

			.counter-block p {
				color: #71717a;
				font-size: 0.9rem;
				line-height: 1.5;
				margin: 0;
				font-weight: 500;
				letter-spacing: -0.01em;
			}

			@media (max-width: 968px) {
				main {
					padding: 5rem 1.5rem;
				}

				.hero-split {
					grid-template-columns: 1fr;
					gap: 4rem;
				}

				.main-headline {
					font-size: 3.2rem;
				}

				.media-container {
					max-width: 520px;
				}

				.counter-row {
					grid-template-columns: repeat(2, 1fr);
					gap: 2.5rem;
				}
			}

			@media (max-width: 560px) {
				main {
					padding: 4rem 1.2rem;
				}

				.main-headline {
					font-size: 2.7rem;
				}

				.sub-bio {
					font-size: 1.05rem;
				}

				.btn-row {
					flex-direction: column;
				}

				.pill-btn {
					width: 100%;
				}

				.counter-row {
					grid-template-columns: 1fr;
					gap: 2rem;
				}

				.photo-card {
					border-radius: 24px;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<div class="hero-split">
				<div class="hero-intro">
					<div class="badge-status">
						Open to research & engineering opportunities
					</div>

					<h1 class="main-headline">
						Hi, I'm <span>Abdullahi</span>
					</h1>

					<p class="sub-bio">
						Mechanical Engineer specialising in
						<strong>
							hydrogen storage modelling, sustainable energy
							systems and QA/QC inspection
						</strong>.
						I use MATLAB, Python, CAD/CAE and experimental methods
						to analyse high-pressure energy systems, support
						renewable-energy projects and prepare structured
						technical documentation.
					</p>

					<div class="btn-row">
						<a href="/blog" class="pill-btn btn-white">
							View my projects ↓
						</a>

						<a
							href="mailto:abdullahiabubakar.ahmed85@gmail.com"
							class="pill-btn btn-outline"
						>
							Get in touch ↗
						</a>
					</div>
				</div>

				<div class="media-container">
					<div
						class="photo-card"
						role="img"
						aria-label="Professional portrait of Abdullahi Abubakar Ahmed"
					>
					</div>

					<a href="/qualifications" class="floating-tag">
						View qualifications
					</a>
				</div>
			</div>

			<div class="counter-row">
				<div class="counter-block">
					<h4>700 bar</h4>
					<p>
						Type IV hydrogen-storage tank model developed using
						RK4 and MATLAB ode45.
					</p>
				</div>

				<div class="counter-block">
					<h4>98/110</h4>
					<p>
						M.Sc. Mechanical Engineering final grade from the
						University of Tuscia.
					</p>
				</div>

				<div class="counter-block">
					<h4>Grade A</h4>
					<p>
						Postgraduate specialisation in Sustainable Energy
						through the SkillBill programme.
					</p>
				</div>
			</div>
		</main>

		<Footer />
	</body>
</html>
```
