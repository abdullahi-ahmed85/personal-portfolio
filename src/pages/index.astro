---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const base = import.meta.env.BASE_URL;
const portraitUrl = `${base}my-portrait.jpg`;
const projectsUrl = `${base}projects/`;
const cvUrl = `${base}Abdullahi-Abubakar-Ahmed-CV.pdf`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>

		<style is:inline>
			:root {
				--page-background: #f7f7f5;
				--surface: #ffffff;
				--surface-soft: #eef1f4;
				--text: #0b0b0b;
				--muted: #4b5563;
				--accent: #2f3b5c;
				--accent-hover: #1f293f;
				--border: #e2e5e9;
			}

			* {
				box-sizing: border-box;
			}

			html {
				background: var(--page-background);
				scroll-behavior: smooth;
			}

			body {
				margin: 0;
				background: var(--page-background);
				color: var(--text);
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 5.5rem 2rem 6rem;
			}

			h1,
			h2,
			h3 {
				font-family: 'Plus Jakarta Sans', sans-serif;
			}

			.intro-section {
				display: grid;
				grid-template-columns: minmax(300px, 0.8fr) minmax(0, 1.2fr);
				gap: 5rem;
				align-items: center;
				min-height: 70vh;
				padding-bottom: 5rem;
				border-bottom: 1px solid var(--border);
			}

			.portrait-frame {
				position: relative;
			}

			.portrait-frame::before {
				content: '';
				position: absolute;
				top: 1.3rem;
				right: -1.3rem;
				bottom: -1.3rem;
				left: 1.3rem;
				border-radius: 28px;
				background: var(--accent);
				opacity: 0.1;
			}

			.portrait {
				position: relative;
				z-index: 1;
				width: 100%;
				aspect-ratio: 4 / 5;
				display: block;
				object-fit: cover;
				object-position: center 18%;
				border: 1px solid var(--border);
				border-radius: 28px;
				background: var(--surface-soft);
				box-shadow: 0 24px 60px rgba(47, 59, 92, 0.16);
			}

			.availability {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				margin-bottom: 1.4rem;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			.availability::before {
				content: '';
				width: 0.65rem;
				height: 0.65rem;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 0 5px rgba(47, 59, 92, 0.1);
			}

			.intro-title {
				max-width: 780px;
				margin: 0 0 1.5rem;
				color: var(--text);
				font-size: clamp(3rem, 6.3vw, 5.3rem);
				font-weight: 800;
				line-height: 1.02;
				letter-spacing: -0.055em;
			}

			.intro-title span {
				color: var(--accent);
			}

			.intro-copy {
				max-width: 720px;
				margin: 0 0 1rem;
				color: var(--muted);
				font-size: 1.12rem;
				line-height: 1.78;
			}

			.intro-copy strong {
				color: var(--text);
				font-weight: 650;
			}

			.action-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				margin-top: 2rem;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 3rem;
				padding: 0.78rem 1.25rem;
				border: 1px solid var(--accent);
				border-radius: 10px;
				font-size: 0.9rem;
				font-weight: 700;
				text-decoration: none;
				transition:
					transform 0.2s ease,
					background 0.2s ease,
					color 0.2s ease;
			}

			.button:hover {
				transform: translateY(-2px);
			}

			.button-primary {
				background: var(--accent);
				color: #ffffff;
			}

			.button-primary:hover {
				background: var(--accent-hover);
			}

			.button-secondary {
				background: transparent;
				color: var(--accent);
			}

			.button-secondary:hover {
				background: var(--surface);
			}

			.about-section {
				display: grid;
				grid-template-columns: 0.72fr 1.28fr;
				gap: 5rem;
				padding: 6rem 0 4rem;
			}

			.section-label {
				margin: 0 0 0.8rem;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			.section-title {
				margin: 0;
				color: var(--text);
				font-size: clamp(2rem, 4vw, 3.2rem);
				line-height: 1.12;
				letter-spacing: -0.04em;
			}

			.about-copy p {
				margin: 0 0 1.25rem;
				color: var(--muted);
				font-size: 1.03rem;
				line-height: 1.8;
			}

			.about-copy p:first-child {
				color: var(--text);
				font-size: 1.16rem;
				font-weight: 500;
			}

			.focus-section {
				padding: 2rem 0 5rem;
			}

			.focus-heading {
				max-width: 720px;
				margin-bottom: 2rem;
			}

			.focus-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}

			.focus-card {
				padding: 1.8rem;
				border: 1px solid var(--border);
				border-radius: 18px;
				background: var(--surface);
				box-shadow: 0 14px 36px rgba(47, 59, 92, 0.06);
			}

			.focus-number {
				display: block;
				margin-bottom: 1rem;
				color: var(--accent);
				font-size: 0.76rem;
				font-weight: 800;
				letter-spacing: 0.12em;
			}

			.focus-card h3 {
				margin: 0 0 0.8rem;
				color: var(--text);
				font-size: 1.25rem;
				letter-spacing: -0.025em;
			}

			.focus-card p {
				margin: 0;
				color: var(--muted);
				line-height: 1.7;
			}

			.closing-section {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 2rem;
				align-items: center;
				padding: 2.3rem;
				border: 1px solid var(--border);
				border-radius: 20px;
				background: var(--surface);
			}

			.closing-section h2 {
				margin: 0 0 0.6rem;
				font-size: clamp(1.7rem, 3vw, 2.4rem);
				letter-spacing: -0.035em;
			}

			.closing-section p {
				max-width: 720px;
				margin: 0;
				color: var(--muted);
				line-height: 1.7;
			}

			@media (max-width: 900px) {
				main {
					padding-top: 4rem;
				}

				.intro-section {
					grid-template-columns: 1fr;
					gap: 3rem;
					min-height: auto;
				}

				.portrait-frame {
					max-width: 480px;
				}

				.about-section {
					grid-template-columns: 1fr;
					gap: 2rem;
				}

				.focus-grid {
					grid-template-columns: 1fr;
				}

				.closing-section {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 600px) {
				main {
					padding: 3.5rem 1.2rem 4rem;
				}

				.intro-title {
					font-size: 2.8rem;
				}

				.intro-copy {
					font-size: 1rem;
				}

				.action-row {
					flex-direction: column;
				}

				.button {
					width: 100%;
				}

				.portrait-frame::before {
					display: none;
				}

				.portrait {
					border-radius: 20px;
				}

				.about-section {
					padding-top: 4rem;
				}

				.closing-section {
					padding: 1.6rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="intro-section" aria-labelledby="intro-title">
				<div class="portrait-frame">
					<img
						class="portrait"
						src={portraitUrl}
						alt="Professional portrait of Abdullahi Abubakar Ahmed"
					/>
				</div>

				<div class="intro-content">
					<div class="availability">
						Open to engineering and research opportunities
					</div>

					<h1 id="intro-title" class="intro-title">
						I'm Abdullahi Ahmed, <span>a Mechanical Engineer.</span>
					</h1>

					<p class="intro-copy">
						I specialise in
						<strong>
							sustainable energy, hydrogen-storage modelling,
							additive manufacturing, and engineering quality
						</strong>.
					</p>

					<p class="intro-copy">
						My work combines numerical simulation, experimental
						validation, and practical engineering experience to
						support reliable energy systems, accurate manufacturing
						processes, and sustainable technical solutions.
					</p>

					<div class="action-row">
						<a
							class="button button-primary"
							href="https://www.linkedin.com/in/abdullahi-abubakar-ahmed-b6baab26b"
							target="_blank"
							rel="noopener noreferrer"
						>
							LinkedIn ↗
						</a>

						<a class="button button-secondary" href={projectsUrl}>
							View Projects
						</a>

						<a
							class="button button-secondary"
							href={cvUrl}
							download
						>
							Download My CV
						</a>
					</div>
				</div>
			</section>

			<section id="about" class="about-section" aria-labelledby="about-title">
				<div>
					<p class="section-label">About Me</p>

					<h2 id="about-title" class="section-title">
						Engineering analysis connected to practical application.
					</h2>
				</div>

				<div class="about-copy">
					<p>
						I am Abdullahi Abubakar Ahmed, a Mechanical Engineer
						with an M.Sc. in Mechanical Engineering and postgraduate
						specialisation in Sustainable Energy.
					</p>

					<p>
						My background combines engineering modelling,
						experimental research, renewable-energy systems,
						additive manufacturing, mechanical inspection, and
						QA/QC practice. I enjoy working on technical problems
						where analysis, measurement, and practical
						implementation must work together.
					</p>

					<p>
						I have developed MATLAB-based thermodynamic models for
						hydrogen-storage systems using mass and energy
						conservation equations, Runge-Kutta methods, and
						adaptive numerical solvers. I have also worked with
						PETG FDM printing, structured-light scanning, reverse
						engineering, dimensional validation, and shrinkage
						compensation.
					</p>

					<p>
						Alongside research, I have gained practical experience
						in solar-PV engineering, mechanical maintenance,
						technical inspection, measurement, documentation, and
						engineering quality.
					</p>

					<p>
						I am interested in engineering and research
						opportunities involving hydrogen technologies,
						renewable energy, digital manufacturing, industrial
						reliability, and sustainable infrastructure.
					</p>
				</div>
			</section>

			<section class="focus-section" aria-labelledby="focus-title">
				<div class="focus-heading">
					<p class="section-label">Areas of Focus</p>

					<h2 id="focus-title" class="section-title">
						Three areas that connect my technical interests and experience.
					</h2>
				</div>

				<div class="focus-grid">
					<article class="focus-card">
						<span class="focus-number">01 / ENERGY</span>

						<h3>Hydrogen & Sustainable Energy</h3>

						<p>
							Hydrogen-storage modelling, thermodynamic analysis,
							renewable-energy systems, solar PV, energy storage,
							and sustainable mobility.
						</p>
					</article>

					<article class="focus-card">
						<span class="focus-number">02 / MODELLING</span>

						<h3>Engineering Modelling & Validation</h3>

						<p>
							MATLAB, numerical methods, transient simulation,
							engineering calculations, experimental measurement,
							and technical data interpretation.
						</p>
					</article>

					<article class="focus-card">
						<span class="focus-number">03 / MANUFACTURING</span>

						<h3>Additive Manufacturing & Quality</h3>

						<p>
							CAD preparation, PETG FDM printing, slicing
							optimisation, structured-light scanning, dimensional
							inspection, reverse engineering, and QA/QC
							documentation.
						</p>
					</article>
				</div>
			</section>

			<section class="closing-section">
				<div>
					<h2>Open to practical engineering collaboration.</h2>

					<p>
						I welcome conversations about sustainable energy,
						hydrogen technologies, additive manufacturing,
						engineering modelling, and industrial quality.
					</p>
				</div>

				<a class="button button-primary" href={projectsUrl}>
					Explore My Projects
				</a>
			</section>
		</main>

		<Footer />
	</body>
</html>
