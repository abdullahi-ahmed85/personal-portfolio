---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About | Abdullahi Abubakar Ahmed"
			description="Mechanical Engineer specialising in hydrogen storage modelling, sustainable energy systems, additive manufacturing, maintenance, and QA/QC inspection."
		/>

		<style is:inline>
			html,
			body {
				margin: 0;
				padding: 0;
				background: #08130d;
				color: #ffffff;
				font-family: Inter, Arial, sans-serif;
			}

			main {
				max-width: 1000px;
				margin: 0 auto;
				padding: 6rem 2rem;
			}

			.hero {
				border-left: 5px solid #22c55e;
				padding-left: 2rem;
				margin-bottom: 4rem;
			}

			.eyebrow {
				display: block;
				margin-bottom: 1rem;
				color: #22c55e;
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}

			h1,
			h2 {
				font-family: "Plus Jakarta Sans", Inter, Arial, sans-serif;
			}

			h1 {
				margin: 0 0 1rem;
				font-size: clamp(2.8rem, 7vw, 4.5rem);
				line-height: 1.05;
				letter-spacing: -0.04em;
			}

			.intro {
				max-width: 760px;
				margin: 0;
				color: #a8b8ad;
				font-size: 1.2rem;
				line-height: 1.75;
			}

			.section {
				margin-top: 2.5rem;
				padding: 2rem;
				background: #111c16;
				border: 1px solid #29292d;
				border-radius: 20px;
			}

			h2 {
				margin: 0 0 1rem;
				font-size: 1.6rem;
				letter-spacing: -0.02em;
			}

			p,
			li {
				color: #d1d5db;
				font-size: 1.02rem;
				line-height: 1.8;
			}

			ul {
				margin-bottom: 0;
				padding-left: 1.25rem;
			}

			li::marker {
				color: #22c55e;
			}

			.links {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				margin-top: 2.5rem;
			}

			.links a {
				padding: 0.85rem 1.2rem;
				border: 1px solid #36363b;
				border-radius: 999px;
				color: #ffffff;
				font-weight: 600;
				text-decoration: none;
			}

			.links a:first-child {
				background: #22c55e;
				border-color: #22c55e;
			}

			@media (max-width: 640px) {
				main {
					padding: 4rem 1.2rem;
				}

				.hero {
					padding-left: 1.2rem;
				}

				.section {
					padding: 1.4rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<span class="eyebrow">About Me</span>
				<h1>Abdullahi Abubakar Ahmed</h1>
				<p class="intro">
					I am a Mechanical Engineer focused on hydrogen-storage modelling,
					sustainable energy systems, additive manufacturing, mechanical
					maintenance, and QA/QC inspection.
				</p>
			</section>

			<section class="section">
				<h2>Engineering focus</h2>
				<p>
					My work combines numerical modelling, experimental research,
					engineering analysis, and practical technical problem-solving. I am
					especially interested in safe and efficient hydrogen technologies,
					renewable-energy infrastructure, and industrial quality systems.
				</p>
			</section>

			<section class="section">
				<h2>Hydrogen and sustainable energy</h2>
				<p>
					During my postgraduate Sustainable Energy specialisation, I developed
					a MATLAB model for the adiabatic blowdown of a 700-bar Type IV
					hydrogen-storage tank. The project used mass and energy conservation
					equations and compared a fourth-order Runge-Kutta method with
					MATLAB's ode45 solver.
				</p>
			</section>

			<section class="section">
				<h2>Additive manufacturing research</h2>
				<p>
					My Master's research at the University of Tuscia examined
					non-contact techniques for estimating distortion in polymeric parts
					produced through Fused Deposition Modelling. The work involved
					dimensional analysis, experimental planning, CAD interpretation, and
					reverse-engineering principles.
				</p>
			</section>

			<section class="section">
				<h2>Professional experience</h2>
				<p>
					My professional background includes freelance mechanical and QA/QC
					inspection, solar-PV engineering at Tamarso Company, and mechanical
					maintenance support at Somtel International Ltd.
				</p>
			</section>

			<section class="section">
				<h2>Education</h2>
				<ul>
					<li>
						M.Sc. Mechanical Engineering, University of Tuscia — 98/110
					</li>
					<li>
						Postgraduate Specialisation in Sustainable Energy, SkillBill —
						60 ECTS, Grade A
					</li>
					<li>
						B.Sc. Mechanical Engineering, Somali National University —
						110/110
					</li>
					<li>Diploma in Project Management, Mogadishu University</li>
				</ul>
			</section>

			<section class="section">
				<h2>Technical capabilities</h2>
				<ul>
					<li>MATLAB, RK4, ode45, and thermodynamic modelling</li>
					<li>Python and engineering data analysis</li>
					<li>SolidWorks, AutoCAD, CAD modelling, and reverse engineering</li>
					<li>Solar-PV sizing, equipment selection, and performance testing</li>
					<li>Mechanical maintenance, fault diagnosis, and reliability support</li>
					<li>Mechanical inspection, QA/QC, and technical documentation</li>
				</ul>
			</section>

			<div class="links">
				<a href="/experience">View experience</a>
				<a href="/qualifications">View qualifications</a>
				<a href="mailto:abdullahiabubakar.ahmed85@gmail.com">Contact me</a>
			</div>
		</main>

		<Footer />
	</body>
</html>
