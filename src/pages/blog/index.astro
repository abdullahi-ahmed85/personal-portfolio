---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

// Pull the collection safely
const posts = await getCollection('blog');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			body {
				background-color: #0f172a;
				color: #f1f5f9;
				font-family: 'Courier New', Courier, monospace, system-ui;
			}
			main {
				max-width: 900px;
				margin: 0 auto;
				padding: 3em 2em;
			}
			.page-title {
				font-size: 2.5em;
				color: #ffffff;
				margin: 0 0 0.2em 0;
				font-weight: 800;
			}
			.page-subtitle {
				color: #94a3b8;
				margin-bottom: 3em;
				font-size: 1.1em;
			}
			.project-list {
				display: flex;
				flex-direction: column;
				gap: 24px;
				padding: 0;
				list-style-type: none;
			}
			.project-card {
				background: #1e293b;
				border: 1px solid #334155;
				border-radius: 8px;
				padding: 1.8em;
				transition: all 0.3s ease;
			}
			.project-card:hover {
				border-color: #3b82f6;
				transform: translateY(-2px);
			}
			.project-title {
				margin: 0;
				font-size: 1.4em;
			}
			.project-title a {
				color: #ffffff;
				text-decoration: none;
				font-weight: 700;
			}
			.project-title a:hover {
				color: #3b82f6;
			}
			.project-meta {
				color: #3b82f6;
				font-size: 0.85em;
				font-weight: bold;
				text-transform: uppercase;
				letter-spacing: 1px;
				margin-top: 0.5em;
			}
			.project-desc {
				color: #cbd5e1;
				margin-top: 0.8em;
				margin-bottom: 0;
				font-size: 0.95em;
				line-height: 1.5;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">[03] RESEARCH & PROJECTS</h1>
			<p class="page-subtitle">Index of structural analyses, automation deployments, and cleaner tech case studies.</p>
			
			<section>
				<ul class="project-list">
					<!-- Static Render Block to guarantee data passes through cleanly -->
					<li class="project-card">
						<h2 class="project-title">
							<a href="/blog/digital-twin/">Digital Twin Real-Time Input Parameter Calibration</a>
						</h2>
						<div class="project-meta">LOG TIMELINE: JUN 2025 - OCT 2025</div>
						<p class="project-desc">Developing automated synchronization between live manufacturing lines and discrete event simulation engines using bootstrap particle filtering at Politecnico di Milano.</p>
					</li>

					<li class="project-card">
						<h2 class="project-title">
							<a href="/blog/hydrogen-storage/">Dynamic Behaviour of Solid Metal Hydride & Gas Hydrogen Storage Tanks</a>
						</h2>
						<div class="project-meta">LOG TIMELINE: SEP 2024 - PRESENT</div>
						<p class="project-desc">Thermodynamic and fluid-structure transient assessment of refilling characteristics under high-pressure variable scenarios within the SKILLBILL European Program.</p>
					</li>

					<li class="project-card">
						<h2 class="project-title">
							<a href="/blog/somalia-grid/">Sustainable Energy Transitions: Macro Somalia Grid Optimization</a>
						</h2>
						<div class="project-meta">LOG TIMELINE: MAY 2025</div>
						<p class="project-desc">Strategic techno-economic analysis modeling the transition of high-cost decentralized diesel grids to smart hybrid solar-photovoltaic networks using BECO data.</p>
					</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>