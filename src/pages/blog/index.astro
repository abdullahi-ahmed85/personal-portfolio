---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Projects & Research | Abdullahi Abubakar Ahmed"
			description="Academic research and engineering projects in additive manufacturing, dimensional metrology, reverse engineering, prototype optimisation, and hydrogen-storage modelling."
		/>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>

		<style is:inline>
			:root {
				--background: #0d0d0e;
				--surface: #171719;
				--surface-soft: #1d1d20;
				--border: #2b2b30;
				--text: #ffffff;
				--muted: #a1a1aa;
				--accent: #ff5a2b;
			}

			* {
				box-sizing: border-box;
			}

			html {
				background: var(--background);
				scroll-behavior: smooth;
			}

			body {
				margin: 0;
				background:
					radial-gradient(
						circle at 85% 4%,
						rgba(255, 90, 43, 0.08),
						transparent 30rem
					),
					var(--background);
				color: var(--text);
				font-family: 'Inter', system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 6.5rem 2rem 5rem;
			}

			h1,
			h2,
			h3 {
				font-family: 'Plus Jakarta Sans', sans-serif;
			}

			.page-header {
				max-width: 850px;
				margin-bottom: 4.5rem;
				padding-left: 2rem;
				border-left: 5px solid var(--accent);
			}

			.eyebrow {
				display: block;
				margin-bottom: 1rem;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}

			.page-header h1 {
				margin: 0 0 1rem;
				font-size: clamp(2.8rem, 6vw, 4.6rem);
				line-height: 1.04;
				letter-spacing: -0.05em;
			}

			.page-header p {
				margin: 0;
				color: var(--muted);
				font-size: 1.12rem;
				line-height: 1.75;
			}

			.featured-project,
			.project-card {
				overflow: hidden;
				border: 1px solid var(--border);
				background: var(--surface);
			}

			.featured-project {
				border-radius: 28px;
			}

			.project-card {
				border-radius: 24px;
				transition:
					transform 0.2s ease,
					border-color 0.2s ease;
			}

			.project-card:hover {
				transform: translateY(-4px);
				border-color: rgba(255, 90, 43, 0.65);
			}

			.featured-image,
			.card-image {
				width: 100%;
				display: block;
				border-bottom: 1px solid var(--border);
			}

			.featured-image {
				aspect-ratio: 16 / 8;
				object-fit: cover;
			}

			.card-image {
				aspect-ratio: 16 / 9;
				object-fit: cover;
			}

			.hydrogen-image {
				object-fit: contain;
				background: #07131f;
			}

			.featured-content {
				display: grid;
				grid-template-columns: 1.15fr 0.85fr;
				gap: 3rem;
				padding: 2.6rem;
			}

			.project-label {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				margin-bottom: 1rem;
				color: var(--accent);
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}

			.project-label::before {
				content: '';
				width: 1.7rem;
				height: 2px;
				background: var(--accent);
			}

			.featured-content h2 {
				margin: 0 0 1rem;
				font-size: clamp(2rem, 4vw, 3rem);
				line-height: 1.12;
				letter-spacing: -0.04em;
			}

			.project-copy,
			.card-content p {
				color: var(--muted);
				line-height: 1.75;
			}

			.project-copy {
				margin: 0 0 1rem;
			}

			.metrics,
			.card-metrics {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 0.8rem;
			}

			.metrics {
				margin-bottom: 1.5rem;
			}

			.metric,
			.card-metric {
				padding: 1rem;
				border: 1px solid var(--border);
				border-radius: 16px;
				background: var(--surface-soft);
			}

			.metric strong,
			.card-metric strong {
				display: block;
				margin-bottom: 0.25rem;
				color: var(--text);
				font-family: 'Plus Jakarta Sans', sans-serif;
			}

			.metric strong {
				font-size: 1.4rem;
			}

			.card-metric strong {
				font-size: 1rem;
			}

			.metric span,
			.card-metric span {
				color: var(--muted);
				line-height: 1.4;
			}

			.metric span {
				font-size: 0.8rem;
			}

			.card-metric span {
				font-size: 0.72rem;
			}

			.side-panel {
				align-self: start;
				padding: 1.5rem;
				border: 1px solid var(--border);
				border-radius: 20px;
				background: var(--surface-soft);
			}

			.side-panel h3 {
				margin: 0 0 1rem;
				font-size: 1.1rem;
			}

			.tag-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}

			.tag {
				display: inline-flex;
				padding: 0.48rem 0.78rem;
				border: 1px solid #393940;
				border-radius: 999px;
				color: #d4d4da;
				font-size: 0.78rem;
				font-weight: 600;
			}

			.projects-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.3rem;
				margin-top: 1.3rem;
			}

			.card-content {
				padding: 2rem;
			}

			.card-content h2 {
				margin: 0 0 0.9rem;
				font-size: 1.65rem;
				line-height: 1.25;
				letter-spacing: -0.03em;
			}

			.card-content p {
				margin: 0 0 1rem;
			}

			.card-metrics {
				gap: 0.65rem;
				margin: 1.3rem 0;
			}

			.card-metric {
				padding: 0.8rem;
				border-radius: 14px;
			}

			.cta {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 2rem;
				align-items: center;
				margin-top: 5rem;
				padding: 2.3rem;
				border: 1px solid rgba(255, 90, 43, 0.35);
				border-radius: 24px;
				background:
					linear-gradient(
						135deg,
						rgba(255, 90, 43, 0.13),
						rgba(255, 90, 43, 0.03)
					),
					var(--surface);
			}

			.cta h2 {
				margin: 0 0 0.6rem;
				font-size: clamp(1.7rem, 3vw, 2.3rem);
				letter-spacing: -0.035em;
			}

			.cta p {
				max-width: 680px;
				margin: 0;
				color: var(--muted);
				line-height: 1.65;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 3.1rem;
				padding: 0.82rem 1.35rem;
				border-radius: 999px;
				background: var(--accent);
				color: #ffffff;
				font-size: 0.9rem;
				font-weight: 700;
				text-decoration: none;
				transition:
					transform 0.2s ease,
					background 0.2s ease;
			}

			.button:hover {
				transform: translateY(-2px);
				background: #ff7149;
			}

			@media (max-width: 900px) {
				main {
					padding-top: 5rem;
				}

				.featured-content {
					grid-template-columns: 1fr;
				}

				.projects-grid {
					grid-template-columns: 1fr;
				}
			}

			@media (max-width: 650px) {
				main {
					padding: 4rem 1.2rem;
				}

				.page-header {
					padding-left: 1.2rem;
					margin-bottom: 3rem;
				}

				.featured-content,
				.card-content {
					padding: 1.5rem;
				}

				.metrics,
				.card-metrics {
					grid-template-columns: 1fr;
				}

				.cta {
					grid-template-columns: 1fr;
					padding: 1.7rem;
				}

				.button {
					width: 100%;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<header class="page-header">
				<span class="eyebrow">Academic Work</span>

				<h1>Projects & Research</h1>

				<p>
					A selection of my work in additive manufacturing,
					dimensional metrology, reverse engineering, prototype
					optimisation, and hydrogen-storage modelling.
				</p>
			</header>

			<section id="thesis" class="featured-project">
				<img
					class="featured-image"
					src="/projects/thesis-dimensional-validation.png"
					alt="Structured-light scanning workflow used for dimensional validation of a PETG FDM test part"
				/>

				<div class="featured-content">
					<div>
						<span class="project-label">
							Featured Master's Thesis
						</span>

						<h2>
							Structured-Light-Assisted Dimensional Validation and
							Axis-Specific Shrinkage Compensation of PETG FDM Parts
						</h2>

						<p class="project-copy">
							My Master's thesis investigated how structured-light
							3D scanning can be used to measure, analyse, and
							compensate for dimensional errors in PETG components
							manufactured through Fused Deposition Modelling.
						</p>

						<p class="project-copy">
							I developed an uncertainty-aware workflow connecting
							CAD modelling, FDM printing, optical scanning,
							scan-to-CAD comparison, reverse-engineering bias
							correction, axis-specific shrinkage calculation,
							compensated reprinting, and independent calliper
							validation.
						</p>

						<div class="metrics">
							<div class="metric">
								<strong>56%</strong>
								<span>
									reduction in X-axis mean absolute error
								</span>
							</div>

							<div class="metric">
								<strong>53%</strong>
								<span>
									reduction in Y-axis mean absolute error
								</span>
							</div>

							<div class="metric">
								<strong>44%</strong>
								<span>
									reduction in Z-axis mean absolute error
								</span>
							</div>
						</div>

						<p class="project-copy">
							The results showed that structured-light scanning can
							support practical dimensional compensation when
							calibration, registration, surface preparation,
							uncertainty, and feature-size limitations are treated as
							part of the measurement process.
						</p>
					</div>

					<aside class="side-panel">
						<h3>Methods and tools</h3>

						<div class="tag-list">
							<span class="tag">PETG FDM</span>
							<span class="tag">Structured-light scanning</span>
							<span class="tag">Scan-to-CAD</span>
							<span class="tag">Geomagic Control X</span>
							<span class="tag">Reverse engineering</span>
							<span class="tag">Uncertainty analysis</span>
							<span class="tag">Shrinkage compensation</span>
							<span class="tag">Calliper validation</span>
						</div>
					</aside>
				</div>
			</section>

			<div class="projects-grid">
				<section id="internship" class="project-card">
					<img
						class="card-image"
						src="/projects/outdoor-furniture-prototype.jpg"
						alt="Colourful modular outdoor-furniture prototype produced through 3D printing"
						loading="lazy"
					/>

					<div class="card-content">
						<span class="project-label">
							Internship Project
						</span>

						<h2>
							3D Printing and Optimisation of a Modular Outdoor
							Furniture Prototype
						</h2>

						<p>
							This project focused on preparing, optimising,
							slicing, printing, and assembling modular components
							for an outdoor-furniture prototype using PETG.
						</p>

						<p>
							I evaluated 100%, 85%, and 75% scales, compared
							assembled and disassembled printing strategies, and
							optimised settings for print time, material use, fit,
							and structural integrity.
						</p>

						<div class="card-metrics">
							<div class="card-metric">
								<strong>9 CFU</strong>
								<span>officially awarded</span>
							</div>

							<div class="card-metric">
								<strong>26%</strong>
								<span>time reduction at 85% scale</span>
							</div>

							<div class="card-metric">
								<strong>28.6%</strong>
								<span>material reduction at 85% scale</span>
							</div>
						</div>

						<p>
							The 85% scale provided the best balance between
							production savings and assembly precision. The final
							prototype was assembled from colour-coded modular parts
							printed with Zortrax M300 Plus and Raise3D systems.
						</p>

						<div class="tag-list">
							<span class="tag">PETG</span>
							<span class="tag">Z-SUITE</span>
							<span class="tag">IdeaMaker</span>
							<span class="tag">Zortrax M300 Plus</span>
							<span class="tag">Raise3D</span>
							<span class="tag">Design optimisation</span>
							<span class="tag">Assembly prototyping</span>
						</div>
					</div>
				</section>

				<section id="hydrogen" class="project-card">
					<img
						class="card-image hydrogen-image"
						src="/projects/hydrogen-storage-model.png"
						alt="Hydrogen storage tank modelling project showing the tank model, assumptions, numerical methods, and pressure, temperature, and mass results"
						loading="lazy"
					/>

					<div class="card-content">
						<span class="project-label">
							Sustainable Energy Project
						</span>

						<h2>Modelling of a Hydrogen Storage Tank</h2>

						<p>
							I developed a MATLAB-based transient model to analyse
							the thermodynamic behaviour of a hydrogen-storage tank
							under changing operating conditions.
						</p>

						<p>
							The model applied mass and energy conservation
							equations to calculate pressure, temperature, and mass
							changes over time. I implemented a fixed-step
							fourth-order Runge-Kutta method and compared its results
							with MATLAB's adaptive ode45 solver.
						</p>

						<p>
							The project strengthened my understanding of
							hydrogen-storage thermodynamics, numerical accuracy,
							transient simulation, and safety considerations relevant
							to hydrogen-refuelling infrastructure.
						</p>

						<div class="tag-list">
							<span class="tag">MATLAB</span>
							<span class="tag">RK4</span>
							<span class="tag">ode45</span>
							<span class="tag">Thermodynamics</span>
							<span class="tag">Mass conservation</span>
							<span class="tag">Energy conservation</span>
							<span class="tag">Transient analysis</span>
						</div>
					</div>
				</section>
			</div>

			<section class="cta">
				<div>
					<h2>Interested in my technical work?</h2>

					<p>
						I am open to research and engineering opportunities
						involving additive manufacturing, dimensional metrology,
						hydrogen technologies, numerical modelling, and sustainable
						energy.
					</p>
				</div>

				<a
					class="button"
					href="mailto:abdullahiabubakar.ahmed85@gmail.com"
				>
					Contact me
				</a>
			</section>
		</main>

		<Footer />
	</body>
</html>
