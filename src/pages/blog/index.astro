---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Work & Contact | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
		
		<style is:inline>
			html, body {
				background-color: #0d0d0e !important;
				background-image: none !important;
				color: #ffffff !important;
				font-family: 'Inter', system-ui, sans-serif;
				margin: 0;
				padding: 0;
				-webkit-font-smoothing: antialiased;
			}
			
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 6rem 2rem;
				background-color: #0d0d0e !important;
			}

			.page-header {
				margin-bottom: 5rem;
				border-left: 5px solid #ff5a2b;
				padding-left: 2rem;
			}

			.page-title {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 3.5rem;
				font-weight: 800;
				color: #ffffff !important;
				margin: 0 0 0.5rem 0;
				letter-spacing: -0.03em;
				line-height: 1.1;
			}

			.page-subtitle {
				color: #a1a1aa !important;
				font-size: 1.3rem;
				font-weight: 500;
				margin: 0;
				max-width: 700px;
				line-height: 1.6;
			}

			.section-heading {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.8rem;
				color: #ffffff !important;
				margin-top: 5rem;
				margin-bottom: 2rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}

			.project-showcase-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
				gap: 2.5rem;
				margin-top: 3rem;
			}

			.work-card {
				display: flex;
				flex-direction: column;
				background: #1a1a1c !important;
				border: 1px solid #27272a !important;
				border-radius: 24px;
				overflow: hidden;
				transition: transform 0.3s ease, border-color 0.3s ease;
			}

			.work-card:hover {
				transform: translateY(-6px);
				border-color: #ff5a2b !important;
			}

			.card-image-display {
				width: 100%;
				height: 280px;
				background-color: #161618;
				background-size: cover;
				background-position: center;
				border-bottom: 1px solid #27272a;
				transition: background-image 0.2s ease-in-out;
			}

			.image-thumbnail-strip {
				display: flex;
				gap: 10px;
				padding: 0.6rem 2rem;
				background: #131315;
				border-bottom: 1px solid #27272a;
			}

			.thumb-preview {
				width: 50px;
				height: 35px;
				border-radius: 6px;
				border: 1px solid #3f3f46;
				background-size: cover;
				background-position: center;
				opacity: 0.5;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.thumb-preview:hover {
				opacity: 1;
				border-color: #ff5a2b;
			}

			.card-inner-content {
				padding: 2rem;
				display: flex;
				flex-direction: column;
				flex-grow: 1;
			}

			.work-meta-tag {
				color: #ff5a2b !important;
				font-size: 0.85rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin-bottom: 0.5rem;
			}

			.work-card h3 {
				font-family: 'Plus Jakarta Sans', sans-serif;
				font-size: 1.6rem;
				font-weight: 700;
				color: #ffffff !important;
				margin: 0 0 1rem 0;
			}

			.work-description {
				color: #a1a1aa !important;
				font-size: 1rem;
				line-height: 1.6;
				margin-bottom: 2rem;
				min-height: 95px;
			}

			.card-actions {
				margin-top: auto;
				display: flex;
				gap: 10px;
			}

			.pill-action-btn {
				display: inline-flex;
				align-items: center;
				padding: 0.6rem 1.4rem;
				border-radius: 9999px;
				font-size: 0.9rem;
				font-weight: 600;
				text-decoration: none;
				transition: all 0.2s ease;
			}

			.btn-filled {
				background-color: #ff5a2b;
				color: #ffffff;
			}

			.btn-filled:hover {
				background-color: #e0481b;
			}

			.contact-wrapper {
				background: #1a1a1c !important;
				border: 1px solid #27272a !important;
				border-radius: 24px;
				padding: 3rem;
				margin-top: 4rem;
			}

			.contact-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 3rem;
			}

			.contact-info p {
				color: #a1a1aa !important;
				font-size: 1.1rem;
				line-height: 1.6;
				margin-bottom: 2rem;
			}

			.contact-method {
				font-size: 1.2rem;
				font-weight: 600;
				color: #ffffff;
				margin-bottom: 0.8rem;
			}

			.contact-method a {
				color: #ff5a2b;
				text-decoration: none;
				transition: color 0.2s ease;
			}

			.contact-method a:hover {
				color: #ffffff;
			}

			.form-group {
				margin-bottom: 1.5rem;
			}

			.form-group label {
				display: block;
				font-size: 0.9rem;
				font-weight: 600;
				color: #a1a1aa;
				margin-bottom: 0.5rem;
			}

			.form-group input, .form-group textarea {
				width: 100%;
				padding: 0.8rem 1rem;
				background-color: #0d0d0e;
				border: 1px solid #27272a;
				border-radius: 8px;
				color: #ffffff;
				font-family: inherit;
				box-sizing: border-box;
			}

			.form-group input:focus, .form-group textarea:focus {
				border-color: #ff5a2b;
				outline: none;
			}

			@media (max-width: 968px) {
				.page-title { font-size: 2.8rem; }
				.project-showcase-grid { grid-template-columns: 1fr; }
				.contact-grid { grid-template-columns: 1fr; gap: 2rem; }
				.contact-wrapper { padding: 1.8rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">Selected Works</h1>
				<p class="page-subtitle">Academic research models, simulation algorithms, and dynamic system architectures.</p>
			</div>

			<section>
				<h2 class="section-heading">Systems Frameworks & Dynamic Modeling Matrix</h2>
				<div class="project-showcase-grid">
					
					<div class="work-card">
						<div id="twin-viewport" class="card-image-display" style="background-image: url('/Picture1.png'); background-position: top center;"></div>
						<div class="image-thumbnail-strip">
							<div class="thumb-preview" style="background-image: url('/Picture1.png');" onclick="document.getElementById('twin-viewport').style.backgroundImage='url(/Picture1.png)'" title="Dashboard View"></div>
							<div class="thumb-preview" style="background-image: url('/image_e15b1e.jpg');" onclick="document.getElementById('twin-viewport').style.backgroundImage='url(/image_e15b1e.jpg)'" title="Physical Laboratory Track"></div>
							<div class="thumb-preview" style="background-image: url('/dashboard_controls.png');" onclick="document.getElementById('twin-viewport').style.backgroundImage='url(/dashboard_controls.png)'" title="Control Settings Engine"></div>
						</div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Thesis Research</div>
							<h3>Digital Twin Model Parameter Calibration Framework</h3>
							<p class="work-description">Engineered a synchronized validation dashboard using Python, MQTT, and InfluxDB linked directly to a physical mechatronic line using bootstrap particle filtering.</p>
							<div class="card-actions">
								<a href="/digital-twin-report.pdf" target="_blank" class="pill-action-btn btn-filled">📄 Open PDF Report</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div class="card-image-display" style="background-image: url('/lego-flowchart.png'); background-position: center center;"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Simulation</div>
							<h3>Lego Production Line Discrete-Event Simulation</h3>
							<p class="work-description">Constructed discrete-event simulation models in Arena for a closed-loop semi-automatic factory line layout, executing bottleneck identification scenarios at Station 2.</p>
							<div class="card-actions">
								<a href="/lego-factory-improving.pdf" target="_blank" class="pill-action-btn btn-filled">📄 View Arena Model</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div class="card-image-display" style="background-image: url('/stochastic-matlab.png'); background-position: center center;"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Operations</div>
							<h3>Two-Stage Stochastic Model Planning & OEE Matrix</h3>
							<p class="work-description">Developed two-stage stochastic models in MATLAB to minimize machinery and labor costs under operational uncertainty. Processed logs to analyze OEE indices, MTTR/MTTF parameters, and buffer allocations.</p>
							<div class="card-actions">
								<a href="/stochastic-planning-report.pdf" target="_blank" class="pill-action-btn btn-filled">📄 View OEE Analysis</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div id="ctrl1-viewport" class="card-image-display" style="background-image: url('/control-bode.png');"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Control Systems</div>
							<h3>Mechanical Actuation Loop Stability Loop Optimization</h3>
							<p class="work-description">Derived linearized Laplace equations of system motion to formulate P, PD, and PI controllers, checking loop margins via Root Locus, Bode, and Nyquist criteria.</p>
							<div class="card-actions">
								<a href="/control-systems-assignment.pdf" target="_blank" class="pill-action-btn btn-filled">📄 View Frequency Profiles</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div class="card-image-display" style="background-image: url('/control-nyquist.png');"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Automation</div>
							<h3>Non-Collocated Motor Speed Closed-Loop Stability Analysis</h3>
							<p class="work-description">Modeled multi-variable asymmetric stiffness structures to assess non-collocated feedback instabilities induced at elevated proportional controller gains.</p>
							<div class="card-actions">
								<a href="/control-systems-assignment.pdf" target="_blank" class="pill-action-btn btn-filled">📄 View Non-Collocated Loops</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div id="ctrl3-viewport" class="card-image-display" style="background-image: url('/simulink-ff.png');"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Simulink</div>
							<h3>Feedforward & PI Feedback Trajectory Tracking Logic</h3>
							<p class="work-description">Programmed motion law algorithms inside MATLAB Simulink to isolate tracking precision metrics under high mechanical damping variations and torque noise constraints.</p>
							<div class="card-actions">
								<a href="/trajectory-optimization-report.pdf" target="_blank" class="pill-action-btn btn-filled">📄 Open Simulink Logic</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div id="beam-viewport" class="card-image-display" style="background-image: url('/beam-modes.png');"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Dynamics</div>
							<h3>Continuous Beam Vibration & Modal Shapes Modality</h3>
							<p class="work-description">Solved slender beam partial differential wave equations to calculate continuous mode shapes $\Phi(x)$ and frequency response functions under concentrated boundary moments.</p>
							<div class="card-actions">
								<a href="/mechanical-dynamics-report.pdf" target="_blank" class="pill-action-btn btn-filled">📄 View Beam Analysis</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div id="wheel-viewport" class="card-image-display" style="background-image: url('/wheel-frf.png');"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • Testing</div>
							<h3>Experimental Modal Analysis of Resilient Rail Wheels</h3>
							<p class="work-description">Processed experimental Frequency Response Functions (FRFs) to compute structural damping values via half-power (-3dB) thresholds and identify modal transformations.</p>
							<div class="card-actions">
								<a href="/mechanical-dynamics-report.pdf" target="_blank" class="pill-action-btn btn-filled">📄 View FRF Parameters</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div id="bridge-viewport" class="card-image-display" style="background-image: url('/bridge-fe-mesh.png');"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">Politecnico di Milano • FEA Structural</div>
							<h3>In-Plane Truss FE Structural Bridge & TMD Optimization</h3>
							<p class="work-description">Assembled global coordinate matrix configurations over 36 nodes under moving train loads, configuring Tuned Mass Dampers to secure a 21.47% resonance peak reduction.</p>
							<div class="card-actions">
								<a href="/bridge-fe-report.pdf" target="_blank" class="pill-action-btn btn-filled">📄 View FEA Matrix</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div class="card-image-display" style="background-image: url('/hydrogen-storage-analysis.png'); background-position: center;"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">University of Tuscia • Renewable Energy</div>
							<h3>Dynamic Variable-Pressure Refilling of Hydrogen Tanks</h3>
							<p class="work-description">Completed transient fluid-structure computational investigations of solid metal hydride storage configurations under dynamic high-pressure refilling cycles.</p>
							<div class="card-actions">
								<a href="/hydrogen-storage-analysis.pdf" target="_blank" class="pill-action-btn btn-filled">📄 Open PDF Analysis</a>
							</div>
						</div>
					</div>

					<div class="work-card">
						<div class="card-image-display" style="background-image: url('/somalia-grid-transition.png'); background-position: center;"></div>
						<div class="card-inner-content">
							<div class="work-meta-tag">University of Tuscia • Infrastructure Grid</div>
							<h3>Decarbonization Transitions & Load Optimization for Somalia</h3>
							<p class="work-description">Designed high-capacity hybrid solar renewable infrastructure and demand-side management schedules using the Banadir Electric Company (BECO) asset grid.</p>
							<div class="card-actions">
								<a href="/somalia-grid-transition.pdf" target="_blank" class="pill-action-btn btn-filled">📄 Open PDF Analysis</a>
							</div>
						</div>
					</div>

				</div>
			</section>

			<section id="contact">
				<h2 class="section-heading">Get In Touch</h2>
				<div class="contact-wrapper">
					<div class="contact-grid">
						<div class="contact-info">
							<p>Have an operational challenge, a technical project scope, or looking to discuss industrial automation and structural mechanics? Let's connect.</p>
							<div class="contact-method">Email: <a href="mailto:Abdirahmans.dhore@gmail.com">Abdirahmans.dhore@gmail.com</a></div>
							<div class="contact-method">LinkedIn: <a href="https://www.linkedin.com/in/dhore" target="_blank" rel="noopener noreferrer">linkedin.com/in/dhore ↗</a></div>
							<div class="contact-method">Location: <span style="color: #ffffff;">Mogadishu, Somalia / Lombardy, Italy</span></div>
						</div>
						
						<form action="https://formspree.io/f/xvGolkOL" method="POST">
							<div class="form-group">
								<label for="name">Name</label>
								<input type="text" id="name" name="name" required placeholder="Your name" />
							</div>
							<div class="form-group">
								<label for="email">Email</label>
								<input type="email" id="email" name="email" required placeholder="your@email.com" />
							</div>
							<div class="form-group">
								<label for="message">Message</label>
								<textarea id="message" name="message" rows="4" required placeholder="Describe your parameters..."></textarea>
							</div>
							<button type="submit" class="pill-action-btn btn-filled" style="border:none; cursor:pointer; width:100%; justify-content:center; font-size:1rem; padding:0.8rem;">Send Message →</button>
						</form>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>