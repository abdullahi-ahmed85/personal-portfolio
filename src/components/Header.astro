---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav class="nav-container">
		<div class="brand">
			<a href="/">Ahmed<span class="dot">.</span></a>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Services</HeaderLink>
			<HeaderLink href="/blog">Work</HeaderLink>
			<HeaderLink href="/qualifications">Qualifications</HeaderLink>
			<HeaderLink href="/experience">Experience</HeaderLink>
		</div>
		<div class="nav-cta">
			<a href="mailto:abdullahiabubakar.ahmed85@gmail.com" class="hire-btn">Hire me →</a>
		</div>
	</nav>
</header>

<style>
	header {
		background-color: #0d0d0e;
		padding: 1.5rem 0;
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.nav-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.brand a {
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 700;
		font-size: 1.4rem;
		color: #ffffff;
		text-decoration: none;
		letter-spacing: -0.03em;
	}
	.brand .dot {
		color: #ff5a2b;
	}
	.internal-links {
		display: flex;
		gap: 2rem;
	}
	.internal-links :global(a) {
		color: #71717a;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: color 0.2s ease;
	}
	.internal-links :global(a:hover), .internal-links :global(a.active) {
		color: #ffffff;
	}
	.hire-btn {
		background-color: #ff5a2b;
		color: #ffffff;
		text-decoration: none;
		padding: 0.6rem 1.4rem;
		border-radius: 9999px;
		font-size: 0.9rem;
		font-weight: 600;
		transition: background-color 0.2s ease;
	}
	.hire-btn:hover {
		background-color: #e0481b;
	}
	@media (max-width: 768px) {
		.internal-links { display: none; }
	}
</style>