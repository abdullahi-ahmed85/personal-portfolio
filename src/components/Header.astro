---
const base = import.meta.env.BASE_URL;

const makeUrl = (route = '') => `${base}${route}`;
const normalize = (value) => value.replace(/\/+$/, '') || '/';
const currentPath = normalize(Astro.url.pathname);

const navigation = [
	{ label: 'Home', route: '' },
	{ label: 'Projects', route: 'projects/' },
	{ label: 'Experience', route: 'experience/' },
	{ label: 'Qualifications', route: 'qualifications/' },
];

const isActive = (route) =>
	currentPath === normalize(makeUrl(route));
---

<header class="site-header">
	<div class="header-inner">
		<nav class="desktop-nav" aria-label="Primary navigation">
			{navigation.map((item) => (
				<a
					href={makeUrl(item.route)}
					class:list={['nav-link', { active: isActive(item.route) }]}
					aria-current={isActive(item.route) ? 'page' : undefined}
				>
					{item.label}
				</a>
			))}
		</nav>

		<a
			class="brand"
			href={makeUrl('')}
			aria-label="Abdullahi Ahmed homepage"
		>
			Abdullahi Ahmed
		</a>

		<div class="header-actions">
			<a
				class="linkedin-link"
				href="https://www.linkedin.com/in/abdullahi-abubakar-ahmed-b6baab26b"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Open Abdullahi Ahmed's LinkedIn profile"
			>
				LinkedIn ↗
			</a>

			<details class="mobile-menu">
				<summary aria-label="Open navigation menu">
					<span></span>
					<span></span>
					<span></span>
				</summary>

				<nav aria-label="Mobile navigation">
					{navigation.map((item) => (
						<a
							href={makeUrl(item.route)}
							class:list={[
								'mobile-link',
								{ active: isActive(item.route) },
							]}
							aria-current={isActive(item.route) ? 'page' : undefined}
						>
							{item.label}
						</a>
					))}

					<a
						class="mobile-linkedin"
						href="https://www.linkedin.com/in/abdullahi-abubakar-ahmed-b6baab26b"
						target="_blank"
						rel="noopener noreferrer"
					>
						LinkedIn ↗
					</a>
				</nav>
			</details>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		border-bottom: 1px solid #e5e7eb;
		background: rgba(247, 247, 245, 0.94);
		backdrop-filter: blur(16px);
	}

	.header-inner {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 2rem;
		max-width: 1400px;
		min-height: 76px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.desktop-nav {
		display: flex;
		align-items: center;
		gap: 2rem;
		justify-self: start;
	}

	.nav-link {
		position: relative;
		padding: 0.55rem 0;
		color: #1f2937;
		font-size: 0.92rem;
		font-weight: 600;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.nav-link:hover,
	.nav-link.active {
		color: #0b0b0b;
	}

	.nav-link.active::after {
		content: '';
		position: absolute;
		right: 0;
		bottom: 0;
		left: 0;
		height: 2px;
		border-radius: 999px;
		background: #2f3b5c;
	}

	.brand {
		justify-self: center;
		color: #0b0b0b;
		font-size: 1.05rem;
		font-weight: 800;
		letter-spacing: -0.025em;
		text-decoration: none;
		white-space: nowrap;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-self: end;
	}

	.linkedin-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.7rem;
		padding: 0.65rem 1.15rem;
		border: 1px solid #2f3b5c;
		border-radius: 10px;
		background: #2f3b5c;
		color: #ffffff;
		font-size: 0.85rem;
		font-weight: 700;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.linkedin-link:hover {
		transform: translateY(-2px);
		border-color: #1f293f;
		background: #1f293f;
	}

	.mobile-menu {
		display: none;
		position: relative;
	}

	.mobile-menu summary {
		display: grid;
		width: 2.8rem;
		height: 2.8rem;
		place-content: center;
		gap: 5px;
		border: 1px solid #d1d5db;
		border-radius: 10px;
		background: #ffffff;
		cursor: pointer;
		list-style: none;
	}

	.mobile-menu summary::-webkit-details-marker {
		display: none;
	}

	.mobile-menu summary span {
		display: block;
		width: 18px;
		height: 2px;
		border-radius: 999px;
		background: #0b0b0b;
	}

	.mobile-menu nav {
		position: absolute;
		top: calc(100% + 0.75rem);
		right: 0;
		display: grid;
		width: min(290px, calc(100vw - 2.4rem));
		padding: 0.75rem;
		border: 1px solid #e5e7eb;
		border-radius: 16px;
		background: #ffffff;
		box-shadow: 0 20px 50px rgba(47, 59, 92, 0.15);
	}

	.mobile-link,
	.mobile-linkedin {
		padding: 0.9rem 1rem;
		border-radius: 10px;
		color: #1f2937;
		font-weight: 650;
		text-decoration: none;
	}

	.mobile-link:hover,
	.mobile-link.active {
		background: #f1f3f5;
		color: #0b0b0b;
	}

	.mobile-linkedin {
		margin-top: 0.45rem;
		background: #2f3b5c;
		color: #ffffff;
		text-align: center;
	}

	@media (max-width: 980px) {
		.header-inner {
			grid-template-columns: 1fr auto;
			min-height: 70px;
			padding: 0 1.2rem;
		}

		.desktop-nav,
		.linkedin-link {
			display: none;
		}

		.brand {
			justify-self: start;
		}

		.mobile-menu {
			display: block;
		}
	}
</style>
