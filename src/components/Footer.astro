---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-intro">
			<a class="footer-brand" href={base}>Abdullahi Ahmed</a>
			<p>
				Mechanical engineer focused on hydrogen-storage modelling,
				sustainable energy, additive manufacturing, and engineering quality.
			</p>
		</div>

		<div class="footer-links" aria-label="Professional profiles">
			<a
				href="mailto:abdullahiabubakar.ahmed85@gmail.com"
			>
				Email
			</a>
			<a
				href="https://www.linkedin.com/in/abdullahi-abubakar-ahmed-b6baab26b"
				target="_blank"
				rel="noopener noreferrer"
			>
				LinkedIn
			</a>
			<a
				href="https://github.com/abdullahi-ahmed85"
				target="_blank"
				rel="noopener noreferrer"
			>
				GitHub
			</a>
		</div>
	</div>

	<div class="footer-bottom">
		<span>© {year} Abdullahi Abubakar Ahmed</span>
		<span>Designed for engineering and research opportunities</span>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid #284533;
		background: #08130d;
	}

	.footer-inner,
	.footer-bottom {
		max-width: 1200px;
		margin: 0 auto;
		padding-right: 2rem;
		padding-left: 2rem;
	}

	.footer-inner {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 3rem;
		padding-top: 3.5rem;
		padding-bottom: 2.5rem;
	}

	.footer-brand {
		color: #ffffff;
		font-size: 1.15rem;
		font-weight: 800;
		text-decoration: none;
	}

	.footer-intro p {
		max-width: 620px;
		margin: 0.8rem 0 0;
		color: #a8b8ad;
		line-height: 1.7;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		align-content: start;
		justify-content: flex-end;
		gap: 0.65rem;
	}

	.footer-links a {
		padding: 0.65rem 0.9rem;
		border: 1px solid #284533;
		border-radius: 999px;
		color: #dce8df;
		font-size: 0.85rem;
		font-weight: 650;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.footer-links a:hover {
		transform: translateY(-2px);
		border-color: #22c55e;
		color: #ffffff;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.2rem;
		padding-bottom: 1.7rem;
		border-top: 1px solid rgba(40, 69, 51, 0.7);
		color: #7f9585;
		font-size: 0.78rem;
	}

	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 1.6rem;
			padding-right: 1.2rem;
			padding-left: 1.2rem;
		}

		.footer-links {
			justify-content: flex-start;
		}

		.footer-bottom {
			flex-direction: column;
			padding-right: 1.2rem;
			padding-left: 1.2rem;
		}
	}
</style>
